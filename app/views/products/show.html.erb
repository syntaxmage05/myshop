<div class="container mt-5">
  <div class="row align-items-start">

    <!-- Left Image -->
    <div class="col-md-4">
      <% if @product.image.present? %>
        <%= image_tag @product.image, class: "img-fluid rounded shadow-sm" %>
      <% end %>
    </div>

    <!-- Right Content -->
    <div class="col-md-8">
      <h2 class="fw-bold product-title"><%= @product.name %></h2>

      <p class="text-primary mb-2">
        <%= @product.category.name %>
      </p>

      <h4 class="fw-bold mb-3 product-price">
        KSH <%= @product.price %>
      </h4>

      <p class="text-muted product-description">
        <%= @product.description %>
      </p>
    </div>

  </div>
</div>