<%# app/views/products/show.html.erb %>
<div class="container py-5">
  <!-- Breadcrumb -->
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb bg-light p-3 rounded">
      <li class="breadcrumb-item"><%= link_to "Home", root_path, class: "text-decoration-none" %></li>
      <li class="breadcrumb-item active" aria-current="page"><%= @product.name %></li>
    </ol>
  </nav>

  <div class="row g-5">
    <!-- Product Image -->
    <div class="col-md-5">
      <div class="border rounded-3 p-4 bg-white text-center">
        <% if @product.image.present? %>
          <%= image_tag @product.image, class: "img-fluid", style: "max-height: 400px;", alt: @product.name %>
        <% else %>
          <div class="bg-light p-5 text-center rounded">
            <span class="text-muted">No image available</span>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Product Details -->
    <div class="col-md-7">
      <span class="badge bg-secondary mb-3"><%= @product.category.name %></span>
      
      <h1 class="display-6 fw-bold mb-3"><%= @product.name %></h1>
      
      <h2 class="text-primary mb-4">
        <%= number_to_currency(@product.price, unit: "KSh ", precision: 2) %>
      </h2>

      <!-- Add to Cart Form -->
      <%= form_with url: line_items_path, method: :post, local: true, class: "mb-4" do %>
        <%= hidden_field_tag :product_id, @product.id %>
        
        <div class="row g-3 align-items-end">
          <div class="col-sm-4">
            <%= label_tag :quantity, "Quantity", class: "form-label fw-semibold" %>
            <%= number_field_tag :quantity, 1, min: 1, 
                  class: "form-control form-control-lg" %>
          </div>
          
          <div class="col-sm-8">
            <%= submit_tag "Add to Cart", 
                  class: "btn btn-primary btn-lg w-100",
                  data: { disable_with: "Adding..." } %>
          </div>
        </div>
      <% end %>

      <!-- Stock Status -->
      <% if @product.respond_to?(:stock_quantity) && @product.stock_quantity.present? %>
        <div class="mb-4">
          <% if @product.stock_quantity > 0 %>
            <span class="text-success">
              <i class="bi bi-check-circle-fill"></i> In Stock
            </span>
            <% if @product.stock_quantity < 10 %>
              <span class="text-warning ms-3">
                <i class="bi bi-exclamation-triangle-fill"></i> Only <%= @product.stock_quantity %> left
              </span>
            <% end %>
          <% else %>
            <span class="text-danger">
              <i class="bi bi-x-circle-fill"></i> Out of Stock
            </span>
          <% end %>
        </div>
      <% end %>

      <!-- Description -->
      <div class="mt-4">
        <h5 class="fw-bold mb-3">Description</h5>
        <p class="text-muted" style="line-height: 1.8;">
          <%= @product.description %>
        </p>
      </div>

      <!-- Product Meta -->
      <div class="mt-4 pt-3 border-top">
        <small class="text-muted d-block mb-2">
          <strong>Category:</strong> <%= link_to @product.category.name, category_path(@product.category), class: "text-decoration-none" %>
        </small>
        <% if @product.respond_to?(:sku) && @product.sku.present? %>
          <small class="text-muted d-block">
            <strong>SKU:</strong> <%= @product.sku %>
          </small>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Related Products -->
  <% if @product.category.products.where.not(id: @product.id).any? %>
    <div class="mt-5 pt-5">
      <h3 class="fw-bold mb-4">Related Products</h3>
      <div class="row g-4">
        <% @product.category.products.where.not(id: @product.id).limit(4).each do |related| %>
          <div class="col-md-3">
            <div class="card h-100 border-0 shadow-sm">
              <% if related.image.present? %>
                <%= image_tag related.image, class: "card-img-top p-3", style: "height: 180px; object-fit: contain;", alt: related.name %>
              <% end %>
              <div class="card-body">
                <h6 class="card-title"><%= link_to related.name, product_path(related), class: "text-decoration-none text-dark stretched-link" %></h6>
                <p class="card-text fw-bold text-primary mb-0"><%= number_to_currency(related.price, unit: "KSh ") %></p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>