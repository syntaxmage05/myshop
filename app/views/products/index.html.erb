<%# app/views/products/index.html.erb %>
<div class="container py-5">
  <h1 class="mb-4">Shop All Products</h1>
  
  <% if @products.any? %>
    <div class="row g-4">
      <% @products.each do |product| %>
        <div class="col-md-3">
          <div class="card h-100 shadow-sm">
            <% if product.image.present? %>
              <%= image_tag product.image, class: "card-img-top p-3", style: "height: 200px; object-fit: contain;" %>
            <% end %>
            <div class="card-body">
              <h5 class="card-title"><%= product.name %></h5>
              <p class="card-text fw-bold text-primary">KSh <%= number_with_delimiter(product.price) %></p>
              <%= link_to "View Product", product_path(product), class: "btn btn-outline-primary btn-sm" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-5">
      <p class="text-muted">No products found.</p>
    </div>
  <% end %>
</div>