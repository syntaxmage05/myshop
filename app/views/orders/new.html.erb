<%# app/views/orders/new.html.erb %>
<div class="container py-5">
  <h1 class="mb-4">Checkout</h1>

  <div class="row">
    <!-- Checkout Form -->
    <div class="col-lg-8">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-4">Shipping Information</h5>
          
          <%= form_with(model: @order, local: true) do |f| %>
            <% if @order.errors.any? %>
              <div class="alert alert-danger">
                <h6><%= pluralize(@order.errors.count, "error") %> prevented your order from being saved:</h6>
                <ul class="mb-0 small">
                  <% @order.errors.full_messages.each do |msg| %>
                    <li><%= msg %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="row g-3">
              <div class="col-md-6">
                <%= f.label :first_name, class: "form-label fw-semibold" %>
                <%= f.text_field :first_name, class: "form-control form-control-lg", placeholder: "John", required: true %>
              </div>
              
              <div class="col-md-6">
                <%= f.label :last_name, class: "form-label fw-semibold" %>
                <%= f.text_field :last_name, class: "form-control form-control-lg", placeholder: "Doe", required: true %>
              </div>
              
              <div class="col-12">
                <%= f.label :email, class: "form-label fw-semibold" %>
                <%= f.email_field :email, class: "form-control form-control-lg", placeholder: "john@example.com", required: true %>
              </div>

              <!-- M-Pesa Phone Number Field -->
              <div class="col-12">
                <%= f.label :phone, "M-Pesa Phone Number", class: "form-label fw-semibold" %>
                <div class="input-group">
                  <span class="input-group-text bg-light">🇰🇪</span>
                  <%= f.text_field :phone, class: "form-control form-control-lg", placeholder: "0712345678", value: "0712345678", required: true %>
                </div>
                <small class="text-muted">
                  <i class="bi bi-info-circle me-1"></i>
                  Enter your M-Pesa registered phone number (e.g., 0712345678 or 254712345678)
                </small>
              </div>
              
              <div class="col-12">
                <%= f.label :address, class: "form-label fw-semibold" %>
                <%= f.text_field :address, class: "form-control form-control-lg", placeholder: "123 Main St", required: true %>
              </div>
              
              <div class="col-md-5">
                <%= f.label :city, class: "form-label fw-semibold" %>
                <%= f.text_field :city, class: "form-control form-control-lg", placeholder: "Nairobi", required: true %>
              </div>
              
              <div class="col-md-4">
                <%= f.label :post_code, class: "form-label fw-semibold" %>
                <%= f.text_field :post_code, class: "form-control form-control-lg", placeholder: "00100", required: true %>
              </div>
            </div>

            <!-- Payment Method Info -->
            <div class="alert alert-info mt-4 d-flex align-items-center">
              <i class="bi bi-shield-check fs-3 me-3"></i>
              <div>
                <strong>Payment via M-Pesa</strong><br>
                <small>You'll receive an STK push prompt on your phone to complete payment</small>
              </div>
            </div>

            <hr class="my-4">

            <div class="d-flex justify-content-between">
              <%= link_to "Back to Cart", cart_path(@cart), class: "btn btn-outline-secondary btn-lg" %>
              <%= f.submit "Place Order", class: "btn btn-primary btn-lg px-5", data: { disable_with: "Processing..." } %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Order Summary -->
    <div class="col-lg-4">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-4">Your Order</h5>
          
          <% @cart.line_items.each do |item| %>
            <div class="d-flex justify-content-between mb-2 small">
              <span><%= item.quantity %>x <%= item.product.name %></span>
              <span>KSh <%= number_with_delimiter(item.total_price) %></span>
            </div>
          <% end %>
          
          <hr>
          
          <div class="d-flex justify-content-between fw-bold">
            <span>Total</span>
            <span class="text-primary fs-5">KSh <%= number_with_delimiter(@cart.total_price) %></span>
          </div>

          <!-- M-Pesa Logo -->
          <div class="text-center mt-4 pt-3 border-top">
            <p class="small text-muted mb-2">Pay with</p>
            <i class="bi bi-phone fs-1 text-success"></i>
            <span class="fw-bold d-block">M-Pesa</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>