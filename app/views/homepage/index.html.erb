<!-- Hero Section -->
<div class="bg-primary bg-opacity-10 py-5 mb-5">
  <div class="container text-center">
    <h1 class="display-4 fw-bold mb-3">Welcome to My Shop</h1>
    <p class="lead text-muted mb-4">Discover amazing products at great prices</p>
    
    <!-- Search Bar -->
    <%= form_with url: root_path, method: :get, class: "row justify-content-center", data: { turbo_frame: "_top" } do |f| %>
      <%= hidden_field_tag :category_id, params[:category_id] if params[:category_id].present? %>
      <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
      <%= hidden_field_tag :min_price, params[:min_price] if params[:min_price].present? %>
      <%= hidden_field_tag :max_price, params[:max_price] if params[:max_price].present? %>
      <div class="col-md-6">
        <div class="input-group">
          <%= text_field_tag :search, params[:search], 
                class: "form-control form-control-lg", 
                placeholder: "Search products...",
                aria_label: "Search products" %>
          <button class="btn btn-primary btn-lg" type="submit">
            <i class="bi bi-search"></i> Search
          </button>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="container mb-5">
  <!-- Breadcrumb & Results Count -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item active" aria-current="page">Home</li>
      </ol>
    </nav>
    <p class="text-muted mb-0">
      <span class="fw-bold"><%= @products.count %></span> products found
    </p>
  </div>

  <div class="row g-4">
    <!-- LEFT SIDEBAR - FILTERS -->
    <div class="col-lg-3">
      <!-- Mobile Filter Toggle -->
      <div class="d-lg-none mb-3">
        <button class="btn btn-outline-secondary w-100" type="button" data-bs-toggle="collapse" data-bs-target="#filterSidebar">
          <i class="bi bi-filters me-2"></i>Show Filters
        </button>
      </div>

      <!-- Filter Sidebar -->
      <div class="collapse d-lg-block" id="filterSidebar">
        <div class="card shadow-sm border-0">
          <div class="card-header bg-white border-0 py-3">
            <h5 class="fw-bold mb-0">
              <i class="bi bi-filters me-2"></i>Categories
            </h5>
          </div>
          
          <div class="card-body pt-0">
            <div class="list-group list-group-flush">
              <!-- All Categories Button -->
              <%= link_to root_path(search: params[:search], sort: params[:sort], min_price: params[:min_price], max_price: params[:max_price]), 
                  class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 ps-0 #{'active fw-bold' unless params[:category_id]}" do %>
                <span>All Products</span>
                <span class="badge bg-primary rounded-pill"><%= @total_products_count %></span>
              <% end %>

              <!-- Category Links -->
              <% @categories.each do |category| %>
                <%= link_to root_path(category_id: category.id, search: params[:search], sort: params[:sort], min_price: params[:min_price], max_price: params[:max_price]), 
                    class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 ps-0 #{'active fw-bold' if params[:category_id].to_i == category.id}" do %>
                  <span><%= category.name %></span>
                  <span class="badge bg-primary rounded-pill"><%= category.products_count %></span>
                <% end %>
              <% end %>
            </div>

            <!-- Clear Filters -->
            <% if params[:category_id].present? || params[:search].present? || params[:sort].present? || params[:min_price].present? || params[:max_price].present? %>
              <hr>
              <%= link_to root_path, class: "btn btn-outline-secondary btn-sm w-100" do %>
                <i class="bi bi-x-circle me-2"></i>Clear All Filters
              <% end %>
            <% end %>
          </div>
        </div>

        <!-- Price Range Filter -->
        <div class="card shadow-sm border-0 mt-4">
          <div class="card-header bg-white border-0 py-3">
            <h5 class="fw-bold mb-0">
              <i class="bi bi-currency-dollar me-2"></i>Price Range
            </h5>
          </div>
          <div class="card-body">
            <%= form_with url: root_path, method: :get, class: "row g-2", local: true, data: { turbo_frame: "_top" } do |f| %>
              <%= hidden_field_tag :category_id, params[:category_id] if params[:category_id].present? %>
              <%= hidden_field_tag :search, params[:search] if params[:search].present? %>
              <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
              
              <div class="col-6">
                <%= number_field_tag :min_price, params[:min_price], class: "form-control form-control-sm", placeholder: "Min", min: 0, step: 0.01 %>
              </div>
              <div class="col-6">
                <%= number_field_tag :max_price, params[:max_price], class: "form-control form-control-sm", placeholder: "Max", min: 0, step: 0.01 %>
              </div>
              <div class="col-12 mt-2">
                <%= submit_tag "Apply", class: "btn btn-primary btn-sm w-100" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT SIDE - PRODUCTS GRID -->
    <div class="col-lg-9">
      <!-- Sort Bar -->
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <span class="text-muted me-2">Sort by:</span>
          <div class="btn-group" role="group">            
            <!-- Newest Sort -->
            <%= link_to root_path(sort: 'newest', category_id: params[:category_id], search: params[:search], min_price: params[:min_price], max_price: params[:max_price]), 
                class: "btn btn-outline-secondary btn-sm #{'active btn-primary text-white' if params[:sort] == 'newest'}" do %>
              <i class="bi bi-clock me-1"></i>Newest
            <% end %>
            
            <!-- Price: Low to High -->
            <%= link_to root_path(sort: 'price_low', category_id: params[:category_id], search: params[:search], min_price: params[:min_price], max_price: params[:max_price]), 
                class: "btn btn-outline-secondary btn-sm #{'active btn-primary text-white' if params[:sort] == 'price_low'}" do %>
              <i class="bi bi-arrow-up me-1"></i>Price: Low to High
            <% end %>
            
            <!-- Price: High to Low -->
            <%= link_to root_path(sort: 'price_high', category_id: params[:category_id], search: params[:search], min_price: params[:min_price], max_price: params[:max_price]), 
                class: "btn btn-outline-secondary btn-sm #{'active btn-primary text-white' if params[:sort] == 'price_high'}" do %>
              <i class="bi bi-arrow-down me-1"></i>Price: High to Low
            <% end %>
          </div>
        </div>
        
        <!-- View Toggle -->
        <div class="btn-group" role="group">
          <button class="btn btn-outline-secondary btn-sm active" title="Grid view">
            <i class="bi bi-grid-3x3-gap-fill"></i>
          </button>
          <button class="btn btn-outline-secondary btn-sm" title="List view">
            <i class="bi bi-list"></i>
          </button>
        </div>
      </div>

      <!-- Active Filters Display -->
      <% if params[:sort].present? || params[:search].present? || params[:min_price].present? || params[:max_price].present? %>
        <div class="mb-3">
          <span class="text-muted me-2">Active filters:</span>
          
          <% if params[:search].present? %>
            <span class="badge bg-light text-dark p-2 me-2">
              Search: "<%= params[:search] %>"
              <%= link_to root_path(sort: params[:sort], category_id: params[:category_id], min_price: params[:min_price], max_price: params[:max_price]), class: "text-danger ms-1", data: { turbo_frame: "_top" } do %>
                <i class="bi bi-x"></i>
              <% end %>
            </span>
          <% end %>
          
          <% if params[:sort].present? %>
            <span class="badge bg-light text-dark p-2 me-2">
              Sort: <%= params[:sort].titleize.gsub('_', ' ') %>
              <%= link_to root_path(category_id: params[:category_id], search: params[:search], min_price: params[:min_price], max_price: params[:max_price]), class: "text-danger ms-1", data: { turbo_frame: "_top" } do %>
                <i class="bi bi-x"></i>
              <% end %>
            </span>
          <% end %>
          
          <% if params[:category_id].present? %>
            <span class="badge bg-light text-dark p-2 me-2">
              Category: <%= @categories.find_by(id: params[:category_id])&.name || 'Selected' %>
              <%= link_to root_path(sort: params[:sort], search: params[:search], min_price: params[:min_price], max_price: params[:max_price]), class: "text-danger ms-1", data: { turbo_frame: "_top" } do %>
                <i class="bi bi-x"></i>
              <% end %>
            </span>
          <% end %>
          
          <% if params[:min_price].present? || params[:max_price].present? %>
            <span class="badge bg-light text-dark p-2 me-2">
              Price: 
              <% if params[:min_price].present? && params[:max_price].present? %>
                <%= number_to_currency(params[:min_price], unit: "KSh ") %> - <%= number_to_currency(params[:max_price], unit: "KSh ") %>
              <% elsif params[:min_price].present? %>
                ≥ <%= number_to_currency(params[:min_price], unit: "KSh ") %>
              <% elsif params[:max_price].present? %>
                ≤ <%= number_to_currency(params[:max_price], unit: "KSh ") %>
              <% end %>
              <%= link_to root_path(category_id: params[:category_id], search: params[:search], sort: params[:sort]), class: "text-danger ms-1", data: { turbo_frame: "_top" } do %>
                <i class="bi bi-x"></i>
              <% end %>
            </span>
          <% end %>
        </div>
      <% end %>

      <!-- Products Grid -->
      <% if @products.any? %>
        <div class="row g-4">
          <% @products.each do |product| %>
            <div class="col-md-6 col-xl-4">
              <div class="card h-100 border-0 shadow-sm hover-shadow">
                <!-- Product Image -->
                <div class="position-relative overflow-hidden" style="height: 200px;">
                  <% if product.image.attached? %>
                    <%= image_tag product.image, 
                        class: "card-img-top w-100 h-100",
                        style: "object-fit: cover;",
                        alt: product.name %>
                  <% else %>
                    <div class="bg-light w-100 h-100 d-flex align-items-center justify-content-center">
                      <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                    </div>
                  <% end %>
                  
                  <!-- New Badge (if product is recent) -->
                  <% if product.created_at > 7.days.ago %>
                    <span class="position-absolute top-0 end-0 bg-success text-white px-3 py-2 m-2 rounded-pill small fw-bold">
                      New
                    </span>
                  <% end %>
                </div>

                <!-- Product Info -->
                <div class="card-body">
                  <!-- Category -->
                  <p class="small text-muted mb-1">
                    <% if product.category.present? %>
                      <%= link_to product.category.name, root_path(category_id: product.category.id), class: "text-decoration-none text-muted" %>
                    <% end %>
                  </p>
                  
                  <!-- Product Name -->
                  <h6 class="card-title fw-bold mb-2">
                    <%= link_to product.name, product_path(product), class: "text-decoration-none text-dark stretched-link" %>
                  </h6>
                  
                  <!-- Rating (Placeholder - replace with actual reviews) -->
                  <div class="d-flex align-items-center mb-2">
                    <div class="text-warning small me-2">
                      <i class="bi bi-star-fill"></i>
                      <i class="bi bi-star-fill"></i>
                      <i class="bi bi-star-fill"></i>
                      <i class="bi bi-star-fill"></i>
                      <i class="bi bi-star-half"></i>
                    </div>
                    <span class="small text-muted">(24)</span>
                  </div>
                  
                  <!-- Price -->
                  <div class="d-flex align-items-center">
                    <span class="h5 fw-bold text-primary mb-0">
                      KSh <%= number_with_delimiter(product.price) %>
                    </span>
                  </div>
                </div>

                <!-- Card Footer with Working Buttons -->
                <div class="card-footer bg-white border-0 pt-0 pb-3">
                  <div class="d-flex gap-2">
                    <!-- Working Add to Cart Button -->
                    <%= button_to line_items_path(product_id: product.id, quantity: 1), 
                        class: "btn btn-primary flex-grow-1",
                        data: { turbo_method: :post, turbo_frame: "_top" } do %>
                      <i class="bi bi-cart-plus me-2"></i>Add to Cart
                    <% end %>
                    
                    <!-- Working Wishlist Button (needs Wishlist model) -->
                    <% if user_signed_in? %>
                      <%= button_to wishlist_items_path(product_id: product.id), 
                          class: "btn btn-outline-secondary",
                          title: "Add to wishlist",
                          data: { turbo_method: :post, turbo_frame: "_top" },
                          method: :post do %>
                        <i class="bi bi-heart"></i>
                      <% end %>
                    <% else %>
                      <%= link_to "#", 
                          class: "btn btn-outline-secondary",
                          title: "Login to add to wishlist" do %>
                        <i class="bi bi-heart"></i>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Pagination placeholder -->
        <div class="text-center mt-5">
          <p class="text-muted">Showing <%= @products.count %> products</p>
        </div>

      <% else %>
        <!-- No Products Found -->
        <div class="text-center py-5">
          <div class="mb-4">
            <i class="bi bi-search" style="font-size: 4rem;"></i>
          </div>
          <h3 class="h4 mb-3">No products found</h3>
          <p class="text-muted mb-4">Try adjusting your search or filter criteria</p>
          <%= link_to "Clear Filters", root_path, class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>